  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_qr_image",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_qr_image",
  "label": "QR Code DGI (image)",
  "fieldtype": "Long Text",
  "insert_after": "custom_dgi_qr_code",
  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1,
  "hidden": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_exchange_je",

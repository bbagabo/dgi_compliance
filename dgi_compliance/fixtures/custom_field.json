  "description": "Numero d'enregistrement legal du client (RCCM ou Identification Nationale). Utilise par la Matrice B et affiche sur la facture normalisee."
 },
 {
  "doctype": "Custom Field",
  "name": "Item-dgi_item_type",
  "dt": "Item",
  "fieldname": "dgi_item_type",
  "label": "Type d'article DGI",
  "fieldtype": "Link",
  "options": "DGI Item Type",

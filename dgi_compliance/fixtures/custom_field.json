  "fieldtype": "Datetime",
  "insert_after": "custom_dgi_first_printed_on",
  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Customer-dgi_customer_type",
  "dt": "Customer",
  "fieldname": "dgi_customer_type",
  "label": "Type de client DGI",
  "fieldtype": "Link",
  "options": "DGI Customer Type",
  "insert_after": "tax_id",
  "description": "PP/PM/PC/PL/AO. Si vide, deduit du Customer Type natif via le mapping (DGI Settings). Determine les champs obligatoires (Matrice B)."
 },
 {
  "doctype": "Custom Field",
  "name": "Customer-dgi_registration_no",
  "dt": "Customer",
  "fieldname": "dgi_registration_no",
  "label": "N d'enregistrement (RCCM / Id. Nat.)",
  "fieldtype": "Data",

  "fieldtype": "Link",
  "options": "Journal Entry",
  "insert_after": "custom_dgi_qr_image",
  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_error",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_error",
  "label": "Erreur DGI",
  "fieldtype": "Small Text",
  "insert_after": "custom_dgi_exchange_je",
  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_print_count",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_print_count",
  "label": "Compteur d'impressions DGI",
  "fieldtype": "Int",
  "insert_after": "custom_dgi_error",

[
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_input_section",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_input_section",
  "label": "DGI - Saisie & Classification",
  "fieldtype": "Section Break",
  "insert_after": "taxes_and_charges",
  "collapsible": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-dgi_invoice_type",
  "dt": "Sales Invoice",
  "fieldname": "dgi_invoice_type",
  "label": "Type de facture DGI",
  "fieldtype": "Link",
  "options": "DGI Invoice Type",
  "insert_after": "custom_dgi_input_section",
  "description": "Vide => deduit automatiquement (FV/EV par defaut, FA/EA pour les avoirs). Selectionnez FT/ET uniquement pour un acompte. Sur un retour, force a FA/EA.",
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_export",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_export",
  "label": "Facture a l'exportation",
  "fieldtype": "Check",
  "insert_after": "dgi_invoice_type",
  "description": "Force le type E* (EV/ET/EA)."
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_input_cb",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_input_cb",
  "fieldtype": "Column Break",
  "insert_after": "custom_dgi_export"
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_reference",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_reference",
  "label": "Reference d'origine (Code DEF/DGI)",
  "fieldtype": "Data",
  "insert_after": "custom_dgi_input_cb",
  "description": "Obligatoire pour les avoirs (FA/EA). Repris de la facture d'origine si liee.",
  "depends_on": "eval:doc.is_return || ['FA','EA'].includes(doc.dgi_invoice_type)"
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_reference_type",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_reference_type",
  "label": "Nature de l'avoir",
  "fieldtype": "Select",
  "options": "\nCOR\nRAN\nRAM\nRRR",
  "insert_after": "custom_dgi_reference",
  "description": "COR=Correction, RAN=Annulation, RAM=Avoir suite reprise, RRR=Remise/ristourne/rabais (Matrice F).",
  "depends_on": "eval:doc.is_return || ['FA','EA'].includes(doc.dgi_invoice_type)"
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_reference_desc",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_reference_desc",
  "label": "Description reference",
  "fieldtype": "Data",
  "insert_after": "custom_dgi_reference_type",
  "depends_on": "eval:doc.is_return || ['FA','EA'].includes(doc.dgi_invoice_type)"
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-dgi_validation_override",
  "dt": "Sales Invoice",
  "fieldname": "dgi_validation_override",
  "label": "Override validation DGI (admin)",
  "fieldtype": "Check",
  "insert_after": "custom_dgi_reference_desc",
  "description": "Effectif uniquement pour les roles autorises (DGI Compliance Settings -> Override Roles). Force l'enregistrement malgre une combinaison bloquee.",
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-dgi_section",
  "dt": "Sales Invoice",
  "fieldname": "dgi_section",
  "label": "Normalisation DGI (e-MCF)",
  "fieldtype": "Section Break",
  "insert_after": "dgi_validation_override",
  "collapsible": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_status",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_status",
  "label": "Statut DGI",
  "fieldtype": "Select",
  "options": "\nPending\nNormalized\nCancelled\nError",
  "insert_after": "dgi_section",
  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1,
  "in_standard_filter": 1,
  "description": "Pending = en attente de normalisation; Normalized = normalisee (postage autorise); Cancelled/Error = voir Erreur DGI."
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_uid",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_uid",
  "label": "DGI UID",
  "fieldtype": "Data",
  "insert_after": "custom_dgi_status",
  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_code_def",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_code_def",
  "label": "Code DEF/DGI",
  "fieldtype": "Data",
  "insert_after": "custom_dgi_uid",
  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_counters",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_counters",
  "label": "Compteurs",
  "fieldtype": "Data",
  "insert_after": "custom_dgi_code_def",
  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_nim",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_nim",
  "label": "NIM e-MCF",
  "fieldtype": "Data",
  "insert_after": "custom_dgi_counters",
  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_datetime",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_datetime",
  "label": "Date/heure DGI",
  "fieldtype": "Data",
  "insert_after": "custom_dgi_nim",
  "read_only": 1,
  "allow_on_submit": 1,
  "no_copy": 1
 },
 {
  "doctype": "Custom Field",
  "name": "Sales Invoice-custom_dgi_qr_code",
  "dt": "Sales Invoice",
  "fieldname": "custom_dgi_qr_code",
  "label": "QR Code DGI (contenu)",
  "fieldtype": "Small Text",

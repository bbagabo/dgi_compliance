{
 "doctype": "DocType", "name": "DGI Tax Group", "module": "DGI Compliance",
 "custom": 0, "engine": "InnoDB", "autoname": "field:code", "track_changes": 1,
 "title_field": "description",
 "fields": [
  {"fieldname": "code", "label": "Code (A-P)", "fieldtype": "Data", "unique": 1, "reqd": 1, "in_list_view": 1, "description": "Groupe de taxe e-DEF (A a P)."},
  {"fieldname": "description", "label": "Description", "fieldtype": "Data", "in_list_view": 1},
  {"fieldname": "rate", "label": "Taux (%)", "fieldtype": "Float", "precision": "4", "in_list_view": 1, "description": "Renseigne par /api/info/taxGroups."},
  {"fieldname": "is_vat", "label": "Soumis a TVA", "fieldtype": "Check", "default": "0"},
